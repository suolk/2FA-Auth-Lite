{
    "manifest_version": 3,
    "name": "Tiny Auth",
    "version": "1.0.0",
    "description": "Generate TOTP codes for GitHub two-factor authentication.",
    "icons": {
        "64": "icons/icon64x64.png"
    },
    "action": {
        "default_title": "Tiny Auth",
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage",
        "clipboardWrite",
        "activeTab"
    ]
}