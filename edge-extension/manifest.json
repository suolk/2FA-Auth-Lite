{
    "manifest_version": 3,
    "name": "Tiny Auth",
    "version": "1.0.0",
    "description": "Generate TOTP codes for two-factor authentication.",
    "icons": {
        "64": "icons/icon64x64.png",
        "128": "icons/icon64x64.png"
    },
    "action": {
        "default_title": "Tiny Auth",
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage",
        "clipboardWrite",
        "activeTab"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "tiny-auth@suolk.com",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": false
            }
        }
    }
}